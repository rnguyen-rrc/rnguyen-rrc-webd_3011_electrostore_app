<h2>Order Invoice</h2>

<p>
  <strong>Name:</strong>
  <%= @order.first_name %> <%= @order.last_name %>
</p>

<p>
  <strong>Address:</strong>
  <%= @order.shipping_street %>,
  <%= @order.shipping_city %>,
  <%= @order.province.name %>,
  <%= @order.shipping_postal_code  %>
</p>

<p>
  <strong>Email:</strong>
  <%= @order.email %>
</p>

<p>
  <strong>Phone:</strong>
  <%= @order.phone %>
</p>

<hr>

<table class="table">
  <thead>
    <tr>
      <th>Product</th>
      <th>Qty</th>
      <th>Price</th>
      <th>HST</th>
      <th>PST</th>
      <th>Total</th>
    </tr>
  </thead>

  <tbody>
    <% @order.order_items.each do |item| %>
      <tr>
        <td><%= item.product.name %></td>
        <td><%= item.quantity %></td>
        <td><%= number_to_currency(item.price_at_purchase) %></td>
        <td><%= number_to_currency(item.hst_amount) %></td>
        <td><%= number_to_currency(item.pst_amount) %></td>
        <td><%= number_to_currency(item.line_total) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<hr>

<div class="row mt-4">
  <div class="col-md-6"></div>

  <div class="col-md-6">
    <div class="card p-3">

      <p class="d-flex justify-content-between">
        <span>Subtotal</span>
        <strong><%= number_to_currency(@order.subtotal) %></strong>
      </p>

      <p class="d-flex justify-content-between">
        <span>HST/GST</span>
        <strong><%= number_to_currency(@order.hst_amount) %></strong>
      </p>

      <p class="d-flex justify-content-between">
        <span>PST</span>
        <strong><%= number_to_currency(@order.pst_amount) %></strong>
      </p>

      <hr>

      <p class="d-flex justify-content-between">
        <strong>Total</strong>
        <strong><%= number_to_currency(@order.total_amount) %></strong>
      </p>

    </div>
  </div>
</div>

<hr class="my-4">

<% unless current_user %>
  <div class="card mt-4 p-4">
    <h4>Create an account</h4>
    <p class="text-muted">Save your details for faster checkout next time.</p>

    <%= form_with url: signup_from_order_path(@order), method: :post, local: true do %>
      <%= text_field_tag :username, nil, class: "form-control mb-2", placeholder: "Username" %>

      <%= password_field_tag :password, nil, class: "form-control mb-2", placeholder: "Password" %>

      <%= password_field_tag :password_confirmation, nil, class: "form-control mb-3", placeholder: "Confirm Password" %>

      <%= submit_tag "Create Account", class: "btn btn-primary w-100" %>
    <% end %>
  </div>
<% end %>