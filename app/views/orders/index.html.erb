<h1 class="mb-4">My Orders</h1>

<% if @orders.any? %>
  <div class="table-responsive">
    <table class="table table-striped table-bordered">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>Status</th>
          <th>Subtotal</th>
          <th>HST</th>
          <th>PST</th>
          <th>Total</th>
          <th>Date</th>
          <th></th>
        </tr>
      </thead>

      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td>#<%= order.id %></td>

            <td>
              <span class="badge <%= order.status == 'paid' ? 'bg-success' : 'bg-warning' %>">
                <%= order.status.capitalize %>
              </span>
            </td>

            <td><%= number_to_currency(order.subtotal) %></td>
            <td><%= number_to_currency(order.hst_amount) %></td>
            <td><%= number_to_currency(order.pst_amount) %></td>
            <td><strong><%= number_to_currency(order.total_amount) %></strong></td>

            <td><%= order.created_at.strftime("%b %d, %Y %H:%M") %></td>

            <td>
              <%= link_to "View", order_path(order), class: "btn btn-sm btn-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="alert alert-info">
    You have no orders yet.
  </div>
<% end %>