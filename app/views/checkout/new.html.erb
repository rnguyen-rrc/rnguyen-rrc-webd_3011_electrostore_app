<div class="row align-items-start">

  <!-- LEFT: Checkout Form -->
  <div class="col-md-8">
    <h1 class="mb-4">Checkout</h1>

    <%= form_with url: checkout_index_path, method: :post, local: true do %>

      <%= text_field_tag :first_name, @user&.first_name, placeholder: "First Name", class: "form-control mb-2" %>
      <%= text_field_tag :last_name, @user&.last_name, placeholder: "Last Name", class: "form-control mb-2" %>
      <%= email_field_tag :email, @user&.email, placeholder: "Email", class: "form-control mb-2" %>
      <%= text_field_tag :phone, @user&.phone, placeholder: "Phone", class: "form-control mb-2" %>

      <%= text_field_tag :street, @user&.street_name, placeholder: "Street", class: "form-control mb-2" %>
      <%= text_field_tag :city, @user&.city, placeholder: "City", class: "form-control mb-2" %>
      <%= text_field_tag :postal_code, @user&.postal_code, placeholder: "Postal Code", class: "form-control mb-2" %>

      <%= select_tag :province_id,
        options_from_collection_for_select(
          Province.all,
          :id,
          :name,
          @user&.province_id
        ),
        prompt: "Select Province",
        class: "form-control mb-3" %>

      <%= submit_tag "Continue to Payment", class: "btn btn-success" %>

    <% end %>
  </div>

  <!-- RIGHT: Order Summary -->
  <div class="col-md-4">
    <div class="card p-3">
      <h4>Order Summary</h4>

      <p class="d-flex justify-content-between">
        <span>Subtotal</span>
        <strong><%= number_to_currency(@subtotal) %></strong>
      </p>

      <!-- HST / GST -->
      <p class="d-flex justify-content-between">
        <span id="hst-label">HST/GST</span>
        <strong id="hst-amount">$0.00</strong>
      </p>

      <!-- PST -->
      <p class="d-flex justify-content-between">
        <span id="pst-label">PST</span>
        <strong id="pst-amount">$0.00</strong>
      </p>

      <hr>

      <p class="d-flex justify-content-between">
        <strong>Total</strong>
        <strong id="total-amount"><%= number_to_currency(@total) %></strong>
      </p>
    </div>
  </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const provinceSelect = document.querySelector("select[name='province_id']");

  function calculateTax(provinceId) {
    if (!provinceId) return;

    fetch(`/provinces/${provinceId}/tax`)
      .then(res => res.json())
      .then(data => {
        const subtotal = <%= @subtotal %>;

        const hstAmount = subtotal * data.hst_rate;
        const pstAmount = subtotal * data.pst_rate;
        const total = subtotal + hstAmount + pstAmount;

        document.getElementById("hst-label").innerText =
          `HST/GST (${(data.hst_rate * 100).toFixed(0)}%)`;

        document.getElementById("pst-label").innerText =
          `PST (${(data.pst_rate * 100).toFixed(0)}%)`;

        document.getElementById("hst-amount").innerText =
          "$" + hstAmount.toFixed(2);

        document.getElementById("pst-amount").innerText =
          "$" + pstAmount.toFixed(2);

        document.getElementById("total-amount").innerText =
          "$" + total.toFixed(2);
      });
  }

  // When user changes province
  provinceSelect.addEventListener("change", function() {
    calculateTax(this.value);
  });

  // NEW: auto-run if province already selected
  if (provinceSelect.value) {
    calculateTax(provinceSelect.value);
  }
});
</script>