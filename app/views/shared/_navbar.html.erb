<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">

    <!-- Brand -->
    <%= link_to "Electrostore", root_path, class: "navbar-brand" %>

    <!-- Toggle -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">

      <!-- LEFT SIDE -->
      <ul class="navbar-nav ms-2 align-items-center">

        <li class="nav-item">
          <%= link_to "Products",
                      products_path,
                      class: "nav-link #{'active' if current_page?(products_path)}" %>
        </li>

        <li class="nav-item">
          <%= link_to "Categories",
                      categories_path,
                      class: "nav-link #{'active' if current_page?(categories_path)}" %>
        </li>

        <!-- 🛒 Cart -->
        <li class="nav-item ms-3">
          <%= link_to cart_path, class: "nav-link position-relative" do %>
            🛒 Cart

            <% if cart_item_count > 0 %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                <%= cart_item_count %>
              </span>
            <% end %>
          <% end %>
        </li>

      </ul>

      <!-- RIGHT SIDE (search only) -->
      <div class="ms-auto">
        <%= form_with url: products_path, method: :get, local: true, class: "d-flex gap-2" do |f| %>

          <%= f.text_field :keyword,
                           value: params[:keyword],
                           placeholder: "Search products...",
                           class: "form-control" %>

          <%= f.collection_select :category_id,
                                  Category.order(:name),
                                  :id,
                                  :name,
                                  { include_blank: "All Categories", selected: params[:category_id] },
                                  { class: "form-select" } %>

          <%= f.submit "Search", class: "btn btn-success" %>

          <% if params[:keyword].present? || params[:category_id].present? %>
            <%= link_to "Clear", products_path, class: "btn btn-outline-light" %>
          <% end %>

        <% end %>
      </div>

    </div>
  </div>
</nav>