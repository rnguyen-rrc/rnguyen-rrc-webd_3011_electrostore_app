<div class="product-show-page container py-4">
  <div class="row g-4 align-items-start">

    <!-- LEFT: IMAGE -->
    <div class="col-12 col-md-6">
      <div class="card shadow-sm p-3">
        <div class="product-show-image-wrapper mb-3">
          <% if @product.image.attached? %>
            <%= image_tag @product.image,
                          class: "product-show-image",
                          alt: @product.name %>
          <% elsif @product.image_url.present? %>
            <%= image_tag @product.image_url,
                          class: "product-show-image",
                          alt: @product.name %>
          <% else %>
            <%= image_tag "https://via.placeholder.com/800x500?text=No+Image",
                          class: "product-show-image",
                          alt: @product.name %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- RIGHT: DETAILS -->
    <div class="col-12 col-md-6">
      <div class="product-detail-card">

        <!-- Title -->
        <h1 class="product-name mb-3"><%= @product.name %></h1>

        <!-- Price (highlighted) -->
        <h3 class="text-primary mb-3">
          <%= number_to_currency(@product.price) %>
        </h3>

        <!-- Stock status -->
        <p class="mb-3">
          <strong>Availability:</strong>
          <% if @product.stock_quantity > 0 %>
            <span class="text-success">In Stock</span>
          <% else %>
            <span class="text-danger">Out of Stock</span>
          <% end %>
        </p>

        <!-- Categories -->
        <div class="mb-3">
          <strong>Categories:</strong><br>
          <% if @product.categories.any? %>
            <% @product.categories.each do |category| %>
              <%= link_to category.name,
                          category_path(category),
                          class: "badge bg-light text-dark border me-1 mb-1" %>
            <% end %>
          <% else %>
            <span class="text-muted">None</span>
          <% end %>
        </div>

        <!-- Description -->
        <div class="mb-4">
          <h5>Description</h5>
          <p class="text-muted"><%= @product.description %></p>
        </div>

        <%= button_to "Add to Cart",
              add_to_cart_path(@product.id),
              method: :post,
              class: "btn btn-success" %>
                
        <!-- Actions -->
        <div class="d-flex gap-2">
          <%= link_to "Back to Products",
                      products_path,
                      class: "btn btn-primary" %>

          <%= link_to "Browse Categories",
                      categories_path,
                      class: "btn btn-outline-secondary" %>
        </div>

      </div>
    </div>

  </div>
</div>