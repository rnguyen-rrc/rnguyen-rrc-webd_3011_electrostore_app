<div class="products-page">
  <h1 class="page-title mb-4">All Products</h1>
  
  <% current_filter = params[:filter] %>

  <p>
    Filter:
    <%= link_to "All", products_path,
        class: ("fw-bold text-primary" if current_filter.blank?) %> |

    <%= link_to "New", products_path(filter: "new"),
        class: ("fw-bold text-primary" if current_filter == "new") %> |

    <%= link_to "Recently Updated", products_path(filter: "recent"),
        class: ("fw-bold text-primary" if current_filter == "recent") %>
  </p>
  
  <% if @products.any? %>

    <!-- Pagination -->
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @products %>
    </div>

    <!-- Products Grid -->
    <div class="row g-4">
      <% @products.each do |product| %>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
          <%= render partial: "product_card", locals: { product: product } %>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @products %>
    </div>

  <% else %>

    <!-- Empty State -->
    <div class="text-center py-5">
      <h4 class="mb-3">No products found</h4>

      <% if params[:keyword].present? %>
        <p class="text-muted mb-3">
          No results found for "<strong><%= params[:keyword] %></strong>".
        </p>
      <% else %>
        <p class="text-muted mb-3">
          There are currently no products available.
        </p>
      <% end %>

      <p class="text-muted mb-4">
        Try adjusting your search or selecting a different category.
      </p>

      <%= link_to "Clear Search",
                  products_path,
                  class: "btn btn-outline-primary" %>
    </div>

  <% end %>
</div>